@page "/"
@rendermode InteractiveServer
@inject IDbContextFactory<LibraryContext> DbFactory

<PageTitle>Bibliotekssystem</PageTitle>

<!-- Topbanner: info vänster | namn center | info höger -->
<div class="home-topbar">
    <div class="home-topbar-left">
        Ett bibliotekshanteringssystem<br />
        byggt i C# &amp; Blazor
    </div>
    <div class="home-topbar-center">
        <span class="home-logo">BIBLIOTEKET</span>
    </div>
    <div class="home-topbar-right">
        Böcker &bull; Medlemmar<br />
        Utlåning &bull; Statistik
    </div>
</div>

<!-- Navigation -->
<nav class="home-nav">
    <a href="/books">BÖCKER</a>
    <a href="/books/new">LÄGG TILL BOK</a>
    <a href="/members">MEDLEMMAR</a>
    <a href="/members/new">REGISTRERA MEDLEM</a>
    <a href="/loans">UTLÅNING</a>
</nav>

<!-- Hero: split-sektion -->
<div class="home-hero">
    <div class="home-hero-left">
        <h1 class="home-hero-title">
            Hantera böcker,
            medlemmar &amp;
            utlåningar<span class="home-dot">.</span>
        </h1>
    </div>
    <div class="home-hero-right">
        @if (loaded)
        {
            <div class="home-stats-grid">
                <div class="home-stat-card">
                    <span class="home-stat-number">@bookCount</span>
                    <span class="home-stat-label">Böcker</span>
                </div>
                <div class="home-stat-card">
                    <span class="home-stat-number">@memberCount</span>
                    <span class="home-stat-label">Medlemmar</span>
                </div>
                <div class="home-stat-card">
                    <span class="home-stat-number">@activeLoanCount</span>
                    <span class="home-stat-label">Aktiva lån</span>
                </div>
                <div class="home-stat-card">
                    <span class="home-stat-number">@overdueLoanCount</span>
                    <span class="home-stat-label">Försenade</span>
                </div>
            </div>

            <div class="home-actions">
                <a href="/books" class="home-action-btn">Visa böcker</a>
                <a href="/members" class="home-action-btn">Visa medlemmar</a>
                <a href="/loans" class="home-action-btn">Hantera utlåning</a>
            </div>
        }
        else
        {
            <p><em>Laddar statistik...</em></p>
        }
    </div>
</div>

@code {
    private int bookCount;
    private int memberCount;
    private int activeLoanCount;
    private int overdueLoanCount;
    private bool loaded;

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        bookCount = await context.Books.CountAsync();
        memberCount = await context.Members.CountAsync();
        activeLoanCount = await context.Loans.CountAsync(l => l.ReturnDate == null);
        overdueLoanCount = await context.Loans.CountAsync(l => l.ReturnDate == null && l.DueDate < DateTime.Now);
        loaded = true;
    }
}
