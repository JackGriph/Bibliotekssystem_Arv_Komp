@page "/members/new"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Registrera medlem</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Registrera ny medlem</h1>
        <p class="page-subtitle">Fyll i medlemmens uppgifter nedan.</p>
    </div>
    <a href="/members" class="action-btn">Tillbaka</a>
</div>

<div class="row">
    <div class="col-md-6">
        <EditForm Model="memberModel" OnValidSubmit="HandleSubmit" FormName="addMember">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="mb-3">
                <label for="memberId" class="form-label">Medlems-ID</label>
                <InputText id="memberId" class="form-control" @bind-Value="memberModel.MemberId" />
                <ValidationMessage For="() => memberModel.MemberId" />
            </div>

            <div class="mb-3">
                <label for="name" class="form-label">Namn</label>
                <InputText id="name" class="form-control" @bind-Value="memberModel.Name" />
                <ValidationMessage For="() => memberModel.Name" />
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">E-post</label>
                <InputText id="email" class="form-control" @bind-Value="memberModel.Email" />
                <ValidationMessage For="() => memberModel.Email" />
            </div>

            <button type="submit" class="btn btn-primary">Registrera</button>
            <a href="/members" class="btn btn-secondary ms-2">Avbryt</a>
        </EditForm>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mt-3">@errorMessage</div>
        }
    </div>
</div>

@code {
    private MemberFormModel memberModel = new();
    private string errorMessage = "";

    private async Task HandleSubmit()
    {
        var request = new
        {
            MemberId = memberModel.MemberId,
            Name = memberModel.Name,
            Email = memberModel.Email
        };

        var response = await Http.PostAsJsonAsync("api/members", request);

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/members");
        }
        else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
        {
            errorMessage = await response.Content.ReadAsStringAsync();
        }
        else
        {
            errorMessage = "Något gick fel vid registrering.";
        }
    }

    private class MemberFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Medlems-ID krävs.")]
        public string? MemberId { get; set; }

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Namn krävs.")]
        public string? Name { get; set; }

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "E-post krävs.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Ange en giltig e-postadress.")]
        public string? Email { get; set; }
    }
}
