@page "/members"
@rendermode InteractiveServer
@inject HttpClient Http

<PageTitle>Medlemmar</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Medlemmar</h1>
        <p class="page-subtitle">Registrerade medlemmar och deras lånestatus.</p>
    </div>
    <a href="/members/new" class="action-btn">Registrera medlem</a>
</div>

@if (members == null)
{
    <p><em>Laddar medlemmar...</em></p>
}
else if (!members.Any())
{
    <p>Inga medlemmar hittades.</p>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Medlems-ID</th>
                <th>Namn</th>
                <th>E-post</th>
                <th>Medlem sedan</th>
                <th>Aktiva lån</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in members)
            {
                <tr>
                    <td>@m.MemberId</td>
                    <td>@m.Name</td>
                    <td>@m.Email</td>
                    <td>@m.MemberSince.ToString("yyyy-MM-dd")</td>
                    <td>
                        <span class="badge @(m.ActiveLoans > 0 ? "bg-warning" : "bg-secondary")">
                            @m.ActiveLoans
                        </span>
                    </td>
                    <td>
                        <a href="members/@m.Id" class="action-btn-sm">Detaljer</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<MemberDto>? members;

    protected override async Task OnInitializedAsync()
    {
        members = await Http.GetFromJsonAsync<List<MemberDto>>("api/members");
    }

    private record MemberDto(int Id, string MemberId, string Name, string Email, DateTime MemberSince, int ActiveLoans);
}
