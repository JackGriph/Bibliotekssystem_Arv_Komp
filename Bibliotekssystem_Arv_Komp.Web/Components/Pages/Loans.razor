@page "/loans"
@rendermode InteractiveServer
@inject IDbContextFactory<LibraryContext> DbFactory

<PageTitle>Utlåning</PageTitle>

<h1>Utlåning</h1>

<div class="card mb-4">
    <div class="card-header">Skapa nytt lån</div>
    <div class="card-body">
        <EditForm Model="loanModel" OnValidSubmit="CreateLoan" FormName="createLoan">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="row g-3">
                <div class="col-md-4">
                    <label for="bookSelect" class="form-label">Bok</label>
                    <InputSelect id="bookSelect" class="form-select" @bind-Value="loanModel.BookId">
                        <option value="0">Välj bok...</option>
                        @foreach (var book in availableBooks)
                        {
                            <option value="@book.Id">@book.Title (@book.ISBN)</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => loanModel.BookId" />
                </div>
                <div class="col-md-4">
                    <label for="memberSelect" class="form-label">Medlem</label>
                    <InputSelect id="memberSelect" class="form-select" @bind-Value="loanModel.MemberId">
                        <option value="0">Välj medlem...</option>
                        @foreach (var member in members)
                        {
                            <option value="@member.Id">@member.Name (@member.MemberId)</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => loanModel.MemberId" />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary">
                        Skapa lån
                    </button>
                </div>
            </div>
        </EditForm>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert @messageClass mt-3">@message</div>
        }
    </div>
</div>

<h3>Aktiva lån</h3>
@if (activeLoans == null)
{
    <p><em>Laddar lån...</em></p>
}
else if (!activeLoans.Any())
{
    <p>Inga aktiva lån.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Bok</th>
                <th>Medlem</th>
                <th>Lånedatum</th>
                <th>Förfallodatum</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var loan in activeLoans)
            {
                <tr class="@(loan.DueDate < DateTime.Now ? "table-danger" : "")">
                    <td>@loan.Item.Title</td>
                    <td>@loan.Member.Name</td>
                    <td>@loan.LoanDate.ToString("yyyy-MM-dd")</td>
                    <td>@loan.DueDate.ToString("yyyy-MM-dd")</td>
                    <td>
                        @if (loan.DueDate < DateTime.Now)
                        {
                            <span class="badge bg-danger">Försenad</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">Aktiv</span>
                        }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-success" @onclick="() => ReturnLoan(loan.Id)">
                            Returnera
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private LoanFormModel loanModel = new();
    private List<Loan>? activeLoans;
    private List<Book> availableBooks = new();
    private List<Member> members = new();
    private string message = "";
    private string messageClass = "alert-info";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        activeLoans = await context.Loans
            .Include(l => l.Item)
            .Include(l => l.Member)
            .Where(l => l.ReturnDate == null)
            .OrderBy(l => l.DueDate)
            .ToListAsync();

        availableBooks = await context.Books
            .Where(b => b.IsAvailable)
            .OrderBy(b => b.Title)
            .ToListAsync();

        members = await context.Members
            .OrderBy(m => m.Name)
            .ToListAsync();
    }

    private async Task CreateLoan()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        var book = await context.Books.FindAsync(loanModel.BookId);
        var member = await context.Members.FindAsync(loanModel.MemberId);

        if (book == null || member == null)
        {
            message = "Bok eller medlem hittades inte.";
            messageClass = "alert-danger";
            return;
        }

        if (!book.IsAvailable)
        {
            message = "Boken är redan utlånad.";
            messageClass = "alert-danger";
            return;
        }

        var memberActiveLoans = await context.Loans
            .Where(l => EF.Property<int>(l, "MemberFkId") == loanModel.MemberId && l.ReturnDate == null)
            .CountAsync();

        if (memberActiveLoans >= 3)
        {
            message = $"{member.Name} har redan 3 aktiva lån (max tillåtet).";
            messageClass = "alert-danger";
            return;
        }

        var loan = new Loan(book, member, 14);
        context.Loans.Add(loan);
        book.IsAvailable = false;
        await context.SaveChangesAsync();

        message = $"Lån skapat: {book.Title} till {member.Name}.";
        messageClass = "alert-success";
        loanModel = new();
        await LoadData();
    }

    private async Task ReturnLoan(int loanId)
    {
        using var context = await DbFactory.CreateDbContextAsync();
        var loan = await context.Loans
            .Include(l => l.Item)
            .FirstOrDefaultAsync(l => l.Id == loanId);

        if (loan == null) return;

        loan.ReturnItem();
        await context.SaveChangesAsync();

        message = $"{loan.Item.Title} har returnerats.";
        messageClass = "alert-success";
        await LoadData();
    }

    private class LoanFormModel
    {
        [System.ComponentModel.DataAnnotations.Range(1, int.MaxValue, ErrorMessage = "Välj en bok.")]
        public int BookId { get; set; }

        [System.ComponentModel.DataAnnotations.Range(1, int.MaxValue, ErrorMessage = "Välj en medlem.")]
        public int MemberId { get; set; }
    }
}
