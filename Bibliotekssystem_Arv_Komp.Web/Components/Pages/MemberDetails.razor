@page "/members/{Id:int}"
@rendermode InteractiveServer
@inject HttpClient Http

<PageTitle>Medlemsdetaljer</PageTitle>

@if (member == null)
{
    <p><em>Laddar medlem...</em></p>
}
else
{
    <div class="page-header">
        <div>
            <h1 class="page-title">@member.Name</h1>
            <p class="page-subtitle">Medlemsdetaljer och lånehistorik.</p>
        </div>
        <a href="/members" class="action-btn">Tillbaka</a>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Medlems-ID</dt>
                <dd class="col-sm-9">@member.MemberId</dd>

                <dt class="col-sm-3">E-post</dt>
                <dd class="col-sm-9">@member.Email</dd>

                <dt class="col-sm-3">Medlem sedan</dt>
                <dd class="col-sm-9">@member.MemberSince.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">Aktiva lån</dt>
                <dd class="col-sm-9">@member.Loans.Count(l => l.ReturnDate == null)</dd>
            </dl>
        </div>
    </div>

    <h3>Lånehistorik</h3>
    @if (member.Loans.Any())
    {
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Bok</th>
                    <th>Lånedatum</th>
                    <th>Förfallodatum</th>
                    <th>Returnerad</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var loan in member.Loans)
                {
                    <tr class="@(loan.ReturnDate == null && loan.DueDate < DateTime.Now ? "table-danger" : "")">
                        <td>@loan.BookTitle</td>
                        <td>@loan.LoanDate.ToString("yyyy-MM-dd")</td>
                        <td>@loan.DueDate.ToString("yyyy-MM-dd")</td>
                        <td>@(loan.ReturnDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                        <td>
                            @if (loan.ReturnDate != null)
                            {
                                <span class="badge bg-secondary">Returnerad</span>
                            }
                            else if (loan.DueDate < DateTime.Now)
                            {
                                <span class="badge bg-danger">Försenad</span>
                            }
                            else
                            {
                                <span class="badge bg-warning">Aktiv</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>Ingen lånehistorik för denna medlem.</p>
    }

    <a href="/members" class="action-btn" style="display:inline-block; margin-top:1rem;">Tillbaka till medlemslistan</a>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private MemberDetailDto? member;

    protected override async Task OnInitializedAsync()
    {
        member = await Http.GetFromJsonAsync<MemberDetailDto>($"api/members/{Id}");
    }

}
