@page "/books"
@rendermode InteractiveServer
@inject HttpClient Http

<PageTitle>Böcker</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Böcker</h1>
        <p class="page-subtitle">Bläddra, sök och hantera bibliotekets boksamling.</p>
    </div>
    <a href="/books/new" class="action-btn">Lägg till bok</a>
</div>

<div class="mb-4" style="max-width: 400px;">
    <input type="text" class="form-control" placeholder="Sök på titel, författare eller ISBN..."
           @bind="searchTerm" @bind:event="oninput" @bind:after="FilterBooks" />
</div>

@if (books == null)
{
    <p><em>Laddar böcker...</em></p>
}
else if (!books.Any())
{
    <p>Inga böcker hittades.</p>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th role="button" @onclick='() => SortBy("title")'>
                    Titel @SortIndicator("title")
                </th>
                <th role="button" @onclick='() => SortBy("author")'>
                    Författare @SortIndicator("author")
                </th>
                <th role="button" @onclick='() => SortBy("isbn")'>
                    ISBN @SortIndicator("isbn")
                </th>
                <th role="button" @onclick='() => SortBy("year")'>
                    År @SortIndicator("year")
                </th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in books)
            {
                <tr>
                    <td>@book.Title</td>
                    <td>@book.Author</td>
                    <td>@book.ISBN</td>
                    <td>@book.PublishedYear</td>
                    <td>
                        @if (book.IsAvailable)
                        {
                            <span class="badge bg-success">Tillgänglig</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Utlånad</span>
                        }
                    </td>
                    <td>
                        <a href="books/@book.Id" class="action-btn-sm">Detaljer</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<BookDto>? books;
    private List<BookDto> allBooks = new();
    private string searchTerm = "";
    private string sortColumn = "title";
    private bool sortAscending = true;

    protected override async Task OnInitializedAsync()
    {
        allBooks = await Http.GetFromJsonAsync<List<BookDto>>("api/books") ?? new();
        FilterBooks();
    }

    private void FilterBooks()
    {
        var filtered = string.IsNullOrWhiteSpace(searchTerm)
            ? allBooks
            : allBooks.Where(b =>
                b.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                b.Author.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                b.ISBN.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
            ).ToList();

        books = ApplySort(filtered);
    }

    private void SortBy(string column)
    {
        if (sortColumn == column)
            sortAscending = !sortAscending;
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
        FilterBooks();
    }

    private List<BookDto> ApplySort(List<BookDto> items)
    {
        return sortColumn switch
        {
            "title" => sortAscending ? items.OrderBy(b => b.Title).ToList() : items.OrderByDescending(b => b.Title).ToList(),
            "author" => sortAscending ? items.OrderBy(b => b.Author).ToList() : items.OrderByDescending(b => b.Author).ToList(),
            "isbn" => sortAscending ? items.OrderBy(b => b.ISBN).ToList() : items.OrderByDescending(b => b.ISBN).ToList(),
            "year" => sortAscending ? items.OrderBy(b => b.PublishedYear).ToList() : items.OrderByDescending(b => b.PublishedYear).ToList(),
            _ => items
        };
    }

    private string SortIndicator(string column)
    {
        if (sortColumn != column) return "";
        return sortAscending ? "\u25b2" : "\u25bc";
    }

}
